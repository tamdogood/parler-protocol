{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read",
      "Bash(cargo build:*)",
      "Bash(cargo clippy:*)",
      "Bash(cargo test:*)",
      "Bash(cargo check:*)",
      "Bash(cargo run:*)",
      "Bash(./scripts/verify.sh:*)",
      "Bash(bash scripts/verify.sh:*)",
      "Bash(bash ./scripts/verify.sh:*)",
      "Bash(./target/debug/parler:*)",
      "Bash(make build:*)",
      "Bash(make test:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git switch:*)",
      "Bash(git stash:*)",
      "Bash(curl http://127.0.0.1:*)",
      "Bash(curl http://localhost:*)",
      "Bash(curl -fsS http://127.0.0.1:*)",
      "Bash(curl -s http://127.0.0.1:*)",
      "Bash(kill:*)",
      "Bash(mktemp:*)",
      "Bash(git push:*)",
      "Bash(gh:*)",
      "Bash(fly:*)",
      "Bash(flyctl:*)",
      "Bash(cargo publish:*)",
      "Bash(npm publish:*)"
    ],
    "deny": [
      "Bash(git reset --hard:*)",
      "Bash(git clean:*)",
      "Bash(rm -rf:*)",
      "Bash(sudo:*)"
    ]
  }
}
